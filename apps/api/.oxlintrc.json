{
    "$schema": "./node_modules/oxlint/configuration_schema.json",
    "env": {
        "node": true,
        "browser": false
    },
    "globals": {
        "Bun": "readonly",
        "Response": "readonly",
        "URL": "readonly",
        "Request": "readonly",
        "console": "readonly",
        "process": "readonly",
        "setInterval": "readonly",
        "__dirname": "readonly"
    },
    "rules": {
        "no-unused-vars": "error",
        "no-undef": "error",
        "no-console": "off",
        "eqeqeq": "error"
    },
    "ignorePatterns": [
        "generated/**",
        "prisma/generated/**"
    ]
}