{
    "$schema": "https://railway.com/railway.schema.json",
    "build": {
        "builder": "NIXPACKS",
        "buildCommand": "cd /app && bun install && cd /app/apps/api && bunx prisma generate"
    },
    "deploy": {
        "startCommand": "bun /app/apps/api/index.ts",
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 10
    }
}